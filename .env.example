# Anthropic API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Strava app credentials — create an app at https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to localhost
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""

# Telegram bot token — create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=""

# Your Telegram user ID — message @userinfobot to get it
TELEGRAM_ALLOWED_USER_ID=""

# PostgreSQL connection string (optional — omit to use in-memory history only)
# Required on Railway; use Railway's managed Postgres or an external provider like Neon
DATABASE_URL=""

# Strava tokens — generated locally by running auth.py, then copied here for Railway
# Not needed for local development (auth.py writes .tokens.json instead)
STRAVA_ACCESS_TOKEN=""
STRAVA_REFRESH_TOKEN=""
STRAVA_TOKEN_EXPIRES_AT=""